# OpenAlex polite pool: an email gets faster, more reliable access (no account needed)
OPENALEX_MAILTO=ktulrich@gmail.com

# Managed Postgres (Neon). Copy the pooled connection string from the Neon dashboard.
# Set the SAME value as a GitHub Actions secret named DATABASE_URL for the batch jobs,
# and in the Vercel project env for the read API.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Web read API base (used by the Next.js app in local dev)
NEXT_PUBLIC_API_BASE=http://localhost:3000/api

# Production site (custom domain configured in Vercel + DNS)
NEXT_PUBLIC_SITE_URL=https://academic-ledger.org

# ── Community layer v0 — C1 ORCID sign-in (Auth.js v5) ───────────────────────────────────────
# Credentials from an ORCID API client you register (see docs/community_layer_v0.md / the C1 notes).
# Register a SANDBOX client first (https://sandbox.orcid.org → Developer Tools), test, then a
# PRODUCTION client (https://orcid.org). Set these in the Vercel project env + GitHub Actions
# secrets; NEVER commit real values. Only the iD, name, and public works list are stored — no password.
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Flip sandbox ↔ production by changing ONLY these two (issuer drives OAuth discovery; api-base the
# public works lookup). Sandbox values shown; production = https://orcid.org and https://pub.orcid.org
ORCID_ISSUER=https://sandbox.orcid.org
ORCID_API_BASE=https://pub.sandbox.orcid.org

# Auth.js session signing. Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-32-byte-base64-string
# Canonical app URL (Auth.js uses it to build the OAuth callback). Local dev: http://localhost:3000
# Production: https://www.academic-ledger.org . (AUTH_URL is the v5 name; NEXTAUTH_URL also honored.)
AUTH_URL=http://localhost:3000
